# ════════════════════════════════════════════════════════════════════════════════
#  PUBLIC REPO — WHITELIST. Ignore EVERYTHING by default, then explicitly allow ONLY
#  the engine (code + method docs). All course materials — copyrighted textbooks,
#  lecture PDFs/transcripts/recordings, learning objectives, the syllabus — and the
#  personal card decks / built .apkg files are PRIVATE and never enter git.
# ════════════════════════════════════════════════════════════════════════════════

# 1) ignore everything at the root
/*

# 2) allow root-level engine files + the directories we need to descend into
!/.gitignore
!/README.md
!/LICENSE
!/requirements.txt
!/.github/
/.github/*
!/.github/workflows/
!/classes/
!/.claude/
!/anki-mcp-server/
!/recaps/

# 3) classes/  →  ONLY the ISF Python tooling + the OKF rulebook
#    (this excludes Week*/, Exam*/, textbooks/, .venv/, course-map.yaml, the syllabus, __pycache__)
/classes/*
!/classes/ISF/
/classes/ISF/*
!/classes/ISF/*.py
!/classes/ISF/okf/
!/classes/ISF/okf/**

# 4) .claude/  →  ONLY the card-authoring skill
/.claude/*
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/anki-cards/
/.claude/skills/anki-cards/*
!/.claude/skills/anki-cards/*.md

# 5) anki-mcp-server/  →  source only, drop build artifacts
/anki-mcp-server/node_modules/
/anki-mcp-server/dist/

# 5b) tests/  →  test CODE only. The golden-deck fixture (tests/fixtures/*.jsonl) is COPYRIGHTED
#     AnKing content — never committed; regenerate it locally via extract_reference_fixture.py.
!/tests/
/tests/*
!/tests/*.py

# 6) belt-and-suspenders — NEVER commit these types, wherever they appear
*.pdf
*.apkg
*.m4a
*.mp4
*.mp3
*.vtt
*.doc
*.docx
*.env
.env
.DS_Store
__pycache__/
*.pyc
classes/ISF/reference/
